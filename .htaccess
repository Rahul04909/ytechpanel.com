# YTech Panels — .htaccess

# Enable RewriteEngine
<IfModule mod_rewrite.c>
    RewriteEngine On
    Options FollowSymLinks

    # Use index.php as the default entry point
    DirectoryIndex index.php

    # Map clean URLs like /about or /products to about.php or products.php
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^(.+)$ $1.php [L,QSA]

    # Route sitemap.xml to sitemap.php
    RewriteRule ^sitemap\.xml$ sitemap.php [L]

    # Route sitemap.xml.gz to sitemap.php (if gzip compression is used)
    # RewriteRule ^sitemap\.xml\.gz$ sitemap.php [L]
</IfModule>

# Compress text files
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# Cache static assets
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
</IfModule>

# Security: Deny access to sensitive files
<FilesMatch "\.(env|sql|md|log|lock)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# Security: Deny directory listing
Options -Indexes
